<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-10">
      <div class="row align-items-center mb-3">
        <div class="col-md-6">
          <h3>サロン一覧</h3>
        </div>
        <div class="col-md-6 text-right">
          <%= link_to 'サロン新規登録', new_admin_salon_path %>
        </div>
      </div>

      <table class="table table-hover table-inverse">
        <thead>
          <tr>
            <th>ID</th>
            <th>名前</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @salons.each do |salon| %>
            <tr>
              <td><%= salon.id %></td>
              <td><%= link_to salon.name, admin_salon_path(salon) %></td>
              <td><%= link_to '編集', edit_admin_salon_path(salon), class: 'btn btn-success' %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>