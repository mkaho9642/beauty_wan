<div class="container">
  <div class="row">
    <div class="col-md-6">
      <h3>レビュー投稿</h3>
      <%= form_with model: @post_reviews, local: true do |f| %>
        <div class="form-group row">
          <%= f.label :review_title, 'タイトル', class: 'col-sm-3 col-form-label' %>
          <div class="col-sm-9">
            <%= f.text_field :review_title, class: 'form-control' %>
          </div>
        </div>

        <div class="form-group row">
          <%= f.label :image, '画像', class: 'col-sm-3 col-form-label' %>
          <div class="col-sm-9">
            <%= f.file_field :image %>
          </div>
        </div>

        <div class="form-group row">
          <%= f.label :review_text, 'レビュー本文', class: 'col-sm-3 col-form-label' %>
          <div class="col-sm-9">
            <%= f.text_area :review_text, class: 'form-control' %>
          </div>
        </div>

        <div class="form-group row">
          <div class="col-sm-9 offset-sm-3">
            <%= f.submit '新規投稿', class: 'btn btn-success text-white' %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
